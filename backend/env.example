# ─────────────────────────────────────────────
#  ShieldHer — Backend Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shieldher?retryWrites=true&w=majority

# JWT secret — make this a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Google Perspective API key (Person 2 will use this)
# Get from: https://developers.perspectiveapi.com/s/docs-get-started
PERSPECTIVE_API_KEY=your_perspective_api_key_here

# Anthropic Claude API key (Person 4 will use this)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Port the Express server will run on
PORT=5000

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
